From 6b73bb1129ef5d85a89eb2110c20fb2ca8c18ca2 Mon Sep 17 00:00:00 2001
From: FlameFlag <git@ps1.sh>
Date: Sun, 21 Jun 2026 02:30:29 +0300
Subject: [PATCH 17/17] image: Use Gdk.Texture fallback before glycin


diff --git a/src/viewers/image.js b/src/viewers/image.js
index e522f346a534f08be00334dd849f6be3d278b501..769c12529103a564d312ebcb06dafbc526f9708b 100644
--- a/src/viewers/image.js
+++ b/src/viewers/image.js
@@ -5,6 +5,7 @@
  */
 
 import Gio from 'gi://Gio';
+import Gdk from 'gi://Gdk';
 import GObject from 'gi://GObject';
 import Gtk from 'gi://Gtk';
 import Gly from 'gi://Gly';
@@ -47,6 +48,18 @@ export const Klass = class ImageRenderer extends Gtk.Picture {
     }
 
     async _loadFile(file) {
+        try {
+            const texture = Gdk.Texture.new_from_file(file);
+            this._texture = texture;
+            this._imageWidth = texture.get_width();
+            this._imageHeight = texture.get_height();
+            this.content_fit = Gtk.ContentFit.SCALE_DOWN;
+            this.set_paintable(texture);
+            return;
+        } catch (e) {
+            // Fall through to glycin for formats Gdk.Texture cannot load directly.
+        }
+
         const loader = Gly.Loader.new(file);
         const image = loader.load();
         this._imageWidth = image.get_width();
