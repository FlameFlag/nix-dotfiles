---
 src/core/mainWindow.js | 4 +++-
 src/viewers/error.js   | 4 ++++
 2 files changed, 7 insertions(+), 1 deletion(-)

diff --git a/src/core/mainWindow.js b/src/core/mainWindow.js
index a5a6973..6708f75 100644
--- a/src/core/mainWindow.js
+++ b/src/core/mainWindow.js
@@ -127,7 +127,9 @@ export class MainWindow extends Adw.ApplicationWindow {
             ?? this.file.get_basename()
             ?? this.file.get_uri());
         this.set_title(title);
-        this.set_resizable(this._renderer.resizable);
+        this.set_resizable(renderer.resizable);
+        renderer.connect('notify::ready', this._onRendererReady.bind(this));
+        this._onRendererReady();
     }
 
     _onRendererFullscreen() {
diff --git a/src/viewers/error.js b/src/viewers/error.js
index 6117527..a87814f 100644
--- a/src/viewers/error.js
+++ b/src/viewers/error.js
@@ -27,6 +27,10 @@ export class ErrorRenderer extends Adw.Bin {
         }, this);
     }
 
+    get ready() {
+        return !!this._ready;
+    }
+
     _init(error) {
         super._init();
 
