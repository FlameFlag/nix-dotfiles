{
    "name": "logitech-battery",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "bun run typecheck && bun run build:gnome",
        "build:gnome": "bun build src/gnome/extension.ts --format=esm --target=browser --minify --external='gi://*' --external='resource:///*' --outfile=dist/gnome/extension.js",
        "check": "biome check . && bun run build && bun run check:dist",
        "check:dist": "bun build dist/gnome/extension.js --target=browser --external='gi://*' --external='resource:///*' --outfile=/tmp/logitech-battery-gnome-check.js",
        "format": "biome format --write .",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "@girs/gjs": "4.0.4",
        "@girs/gnome-shell": "50.0.0",
        "@girs/upowerglib-1.0": "1.91.1-4.0.0-rc.17",
        "@types/bun": "1.3.14",
        "typescript": "6.0.3"
    }
}
