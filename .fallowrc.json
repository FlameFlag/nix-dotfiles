{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "dotfiles/.chezmoiscripts/*.ts",
    "dotfiles/dot_pi/agent/extensions/*.ts"
  ],
  "dynamicallyLoaded": ["dotfiles/.chezmoi-lib/**/*.ts"],
  "ignoreDependencies": [
    "consola",
    "envalid",
    "execa",
    "ky",
    "p-limit",
    "pathe",
    "tempy",
    "type-fest",
    "valibot"
  ],
  "workspaces": {
    "patterns": ["dotfiles/.chezmoi-lib", "dotfiles/.chezmoiscripts"]
  },
  "duplicates": {
    "mode": "semantic",
    "minTokens": 30,
    "minLines": 4,
    "ignore": ["dotfiles/.chezmoiscripts/*.ts"]
  },
  "health": {
    "maxCyclomatic": 12,
    "maxCognitive": 10,
    "maxCrap": 20
  },
  "ignorePatterns": [
    "**/*.tmpl",
    "**/.DS_Store",
    "node_modules/**",
    "scripts/hide-comment.gql"
  ]
}
