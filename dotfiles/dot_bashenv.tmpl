# Keep bootstrap-managed tools visible in non-interactive bash.
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) PATH="$HOME/.local/bin:$PATH" ;;
esac
case ":$PATH:" in
  *":$HOME/.cargo/bin:"*) ;;
  *) PATH="$HOME/.cargo/bin:$PATH" ;;
esac
export PATH

export UV_PYTHON_PREFERENCE="${UV_PYTHON_PREFERENCE:-only-managed}"
