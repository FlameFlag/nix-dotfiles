# Fall back to a common terminfo entry on remote hosts without Ghostty support.
shopt -s array_expand_once globskipdots

if [[ "$TERM" == "xterm-ghostty" ]] && ! infocmp xterm-ghostty &>/dev/null; then
  export TERM=xterm-256color
fi

_path_prepend_once() {
  local -n path_ref=$1
  local dir

  shift
  for dir; do
    [[ -n "$dir" && ":$path_ref:" != *":$dir:"* ]] && path_ref="$dir:$path_ref"
  done
}

_command_wrapper() {
  local -r command_name=$1
  local -r command_path=$2
  local quoted_path

  printf -v quoted_path '%#q' "$command_path"
  eval "$command_name() { command $quoted_path \"\$@\"; }"
}

# Prefer user-local tools installed by Scaffold and language toolchains.
_path_prepend_once PATH \
  "$HOME/.pi/agent/bin" \
  "$HOME/.bun/bin" \
  "$HOME/.bun/install/global/node_modules/.bin" \
  "$HOME/.cache/.bun/bin" \
  "$HOME/.npm/bin" \
  "$HOME/.local/bin" \
  "$HOME/.local/share/nix-dotfiles/immutable/bin" \
  "$HOME/.cargo/bin" \
  "$HOME/.go/bin" \
  "$HOME/.yarn/bin"
if [[ -d /run/wrappers/bin ]]; then
  _path_prepend_once PATH /run/wrappers/bin
fi
export PATH

_immutable_wrapper_marker="# nix-dotfiles: immutable-wrapper"
_is_immutable_wrapper_path() {
  [[ -f "$1" ]] && command grep -Fqx "$_immutable_wrapper_marker" "$1" 2>/dev/null
}
_is_immutable_wrapper_command() {
  local command_path
  command_path="$(command -v "$1" 2>/dev/null)" || return 1
  _is_immutable_wrapper_path "$command_path"
}

_nix_dotfiles_flake="${NIX_DOTFILES_FLAKE:-}"
if [[ -z "$_nix_dotfiles_flake" ]]; then
  for _nix_dotfiles_dir in "/etc/nixos" "$HOME/Developer/nix-dotfiles" "$HOME/nix-dotfiles"; do
    [[ -f "$_nix_dotfiles_dir/flake.nix" ]] || continue
    _nix_dotfiles_flake="$_nix_dotfiles_dir"
    break
  done
fi
if [[ -z "$_nix_dotfiles_flake" ]]; then
  _nix_dotfiles_flake="/etc/nixos"
fi
if [[ -d "$_nix_dotfiles_flake" ]]; then
  _nix_dotfiles_flake="$(
    cd -P -- "$_nix_dotfiles_flake" 2>/dev/null \
      && pwd \
      || printf '%s\n' "$_nix_dotfiles_flake"
  )"
fi
unset _nix_dotfiles_dir

_immutable_nix_host=0
if _is_immutable_wrapper_command nix; then
  _immutable_nix_host=1
fi
_portable_nix_host=0
if ((_immutable_nix_host == 1)) || [[ ! -e /etc/NIXOS ]]; then
  _portable_nix_host=1
fi

_startup_command() {
  local command_path
  command_path="$(command -v "$1" 2>/dev/null)" || return 1
  if [[ "${2:-}" != "allow-wrapper" ]] && _is_immutable_wrapper_path "$command_path"; then
    command_path="$(PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin" command -v "$1" 2>/dev/null)" || return 1
  fi
  [[ -n "$command_path" ]] || return 1
  printf '%s\n' "$command_path"
}

# Bail out for non-interactive shells (e.g. `ssh host cmd`, scp).
# Everything below assumes an interactive prompt — running it on every
# non-interactive ssh invocation is both noisy (starship/atuin warnings)
# and slow.
[[ $- != *i* ]] && return

# Oh-My-Bash Configuration
export OSH="$HOME/.oh-my-bash"
OSH_THEME=""  # Disabled — using starship

# Plugins
plugins=(git bashmarks)

# Completions
completions=(git ssh system)
if _startup_command gh >/dev/null; then
  completions+=(gh)
fi

# Aliases (oh-my-bash)
aliases=()

source "$OSH/oh-my-bash.sh"

# Tool Integrations (cached init files)
_starship_bin="$(_startup_command starship 2>/dev/null || true)"
if [[ -n "$_starship_bin" ]]; then
  _command_wrapper starship "$_starship_bin"
fi
if [[ -n "$_starship_bin" && -r "$HOME/.cache/starship/init.bash" ]]; then
  source "$HOME/.cache/starship/init.bash"
elif [[ -n "$_starship_bin" ]]; then
  eval "$("$_starship_bin" init bash)"
fi
unset _starship_bin
if _startup_command tv >/dev/null && [[ -r "$HOME/.cache/television/init.bash" ]]; then
  source "$HOME/.cache/television/init.bash"
fi
_fzf_bin="$(_startup_command fzf 2>/dev/null || true)"
if [[ -n "$_fzf_bin" ]]; then
  _command_wrapper fzf "$_fzf_bin"
  eval "$("$_fzf_bin" --bash)"
fi
unset _fzf_bin
_atuin_bin="$(_startup_command atuin allow-wrapper 2>/dev/null || true)"
if [[ -t 0 && -t 1 && -n "$_atuin_bin" && -r "$HOME/.cache/atuin/init.bash" ]]; then
  _command_wrapper atuin "$_atuin_bin"
  source "$HOME/.cache/atuin/init.bash"
  __atuin_search_cmd() {
    local -a search_args=("$@")
    local result_file status

    result_file="$(mktemp)" || return 1
    ATUIN_SHELL=bash ATUIN_LOG=error ATUIN_QUERY=$READLINE_LINE atuin search "${search_args[@]}" -i --result-file "$result_file" 1>&2
    status=$?
    cat "$result_file"
    rm -f "$result_file"
    return "$status"
  }
fi
unset _atuin_bin

# Completions (cached)
for f in "$HOME/.cache/bash/completions"/*; do
  [[ -f "$f" ]] && source "$f"
done

# Use 1Password locally, but preserve sshd's forwarded agent in SSH sessions.
{{- if eq .chezmoi.os "darwin" }}
_1p_ssh_auth_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- else }}
_1p_ssh_auth_sock="$HOME/.1password/agent.sock"
{{- end }}
if [[ -z "${SSH_CONNECTION:-}" ]]; then
  export SSH_AUTH_SOCK="$_1p_ssh_auth_sock"
fi
unset _1p_ssh_auth_sock

# Environment
export EDITOR="hx"
export VISUAL="hx"

# Aliases
alias v="hx"
alias vi="hx"
alias vim="hx"
alias h="hx"
alias l="eza --icons"
alias ll="eza -la --icons"
alias la="eza -la --icons"
alias lt="eza --tree --icons"
alias cat="bat"
alias btop="zellij-theme-run btop"
alias htop="zellij-theme-run btop"
alias neofetch="pfetch"
alias top="zellij-theme-run btop"

# yt-dlp shortcuts
_yt_dlp_script() {
  env -u PROMPT_MULTILINE_INDICATOR yt-dlp-script "$@"
}
alias m4a="_yt_dlp_script m4a"
alias m4a-cut="_yt_dlp_script m4a-cut"
alias mp3="_yt_dlp_script mp3"
alias mp3-cut="_yt_dlp_script mp3-cut"
alias mp4="_yt_dlp_script mp4"
alias mp4-cut="_yt_dlp_script mp4-cut"

# Agents Aliases
alias cc="claude --allow-dangerously-skip-permissions"
alias oo="opencode"
free() {
  local runner
  runner="$(command -v system-runner)"
  if [[ -z "$runner" ]]; then
    printf '%s\n' "free: system-runner is not installed yet; install system-run-mcp first" >&2
    return 127
  fi
  sudo -n "$runner" "$@"
}
f() {
  free "$@"
}
cx() {
  zellij-theme-run codex "$@"
}
cxg() {
  zellij-theme-run codex -c mcp_servers.ghidra.enabled=true -c mcp_servers.lldb.enabled=true "$@"
}

# Nix
{{- if eq .chezmoi.os "darwin" }}
update() {
  nix flake update --flake "$_nix_dotfiles_flake" "$@"
}
rebuild() {
  nh darwin switch "$_nix_dotfiles_flake" "$@"
}
check() {
  free darwin-rebuild check --flake "$_nix_dotfiles_flake" "$@"
}
micfix() {
  free killall coreaudiod "$@"
}
{{- else }}
update() {
  if ((_portable_nix_host == 1)); then
    nix run "$_nix_dotfiles_flake#immutable-activate" -- --flake "$_nix_dotfiles_flake" --update --host-update "$@"
    return
  fi
  nix flake update --flake "$_nix_dotfiles_flake" "$@"
}
rebuild() {
  if ((_portable_nix_host == 1)); then
    nix run "$_nix_dotfiles_flake#immutable-activate" -- --flake "$_nix_dotfiles_flake" "$@"
    return
  fi
  free nh os switch "$_nix_dotfiles_flake" "$@"
}
check() {
  nix flake check "$_nix_dotfiles_flake" "$@"
  if ((_portable_nix_host == 1)); then
    nix build "$_nix_dotfiles_flake#immutable-profile"
  fi
}
micfix() {
  systemctl --user restart pipewire pipewire-pulse wireplumber "$@"
}
{{- end }}
alias cza="chezmoi apply --force"

# yazi with cwd sync
function yy() {
  local tmp cwd

  tmp="$(mktemp -t "yazi-cwd.XXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

# shadow system python
export UV_PYTHON_PREFERENCE="only-managed"

function python()  { uv run python "$@"; }
function python3() { uv run python3 "$@"; }
function pip() {
  [[ -z "$VIRTUAL_ENV" && ! -d ".venv" ]] && uv venv -q
  uv pip "$@"
}
function pip3() {
  [[ -z "$VIRTUAL_ENV" && ! -d ".venv" ]] && uv venv -q
  uv pip "$@"
}

if type complete >/dev/null 2>&1; then
  if declare -F _fzf_path_completion >/dev/null 2>&1; then
    complete -o bashdefault -o default -F _fzf_path_completion python python3 pip pip3
  else
    complete -o bashdefault -o default -f python python3 pip pip3
  fi
fi

# fzf Configuration
export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border
  --color=bg+:#414559,bg:#303446,spinner:#f4b8e4,hl:#e78284
  --color=fg:#c6d0f5,header:#e78284,info:#f4b8e4,pointer:#f4b8e4
  --color=marker:#babbf1,fg+:#c6d0f5,prompt:#f4b8e4,hl+:#e78284
  --color=selected-bg:#51576d,border:#737994,label:#c6d0f5"

# Zoxide (must be at the end of .bashrc)
if _startup_command zoxide >/dev/null && [[ -r "$HOME/.cache/zoxide/init.bash" ]]; then
  source "$HOME/.cache/zoxide/init.bash"
  alias cd="z"
fi

unset -f _path_prepend_once _command_wrapper _is_immutable_wrapper_path _is_immutable_wrapper_command _startup_command
unset _immutable_wrapper_marker _immutable_nix_host _portable_nix_host
