# --- Oh-My-Bash Configuration ---
export OSH="$HOME/.oh-my-bash"
OSH_THEME=""  # Disabled — using starship

# --- Plugins ---
plugins=(git bashmarks progress)

# --- Completions ---
completions=(git gh ssh system)

# --- Aliases (oh-my-bash) ---
aliases=(general)

source "$OSH/oh-my-bash.sh"

# --- Tool Integrations (cached init files) ---
source "$HOME/.cache/starship/init.bash"
source "$HOME/.cache/zoxide/init.bash"
source "$HOME/.cache/television/init.bash"
eval "$(fzf --bash)"
source "$HOME/.cache/atuin/init.bash"
atuin-bind -m emacs '\C-r' atuin-search-emacs

# --- Completions (cached) ---
for f in "$HOME/.cache/bash/completions"/*; do
  [ -f "$f" ] && source "$f"
done

# --- 1Password SSH Agent ---
{{- if eq .chezmoi.os "darwin" }}
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- else }}
export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
{{- end }}

# --- Environment ---
export EDITOR="hx"
export VISUAL="hx"

# --- Aliases ---
alias v="hx"
alias vi="hx"
alias vim="hx"
alias h="hx"
alias l="eza --icons"
alias ll="eza -la --icons"
alias la="eza -la --icons"
alias lt="eza --tree --icons"
alias cat="bat"
alias htop="btop"
alias neofetch="pfetch"
alias grep="rg"
alias find="fd"
alias du="dust"
alias df="duf"
alias sed="sd"
alias ps="procs"
alias top="btm"

# yt-dlp shortcuts
alias m4a="yt-dlp-script m4a"
alias m4a-cut="yt-dlp-script m4a-cut"
alias mp3="yt-dlp-script mp3"
alias mp3-cut="yt-dlp-script mp3-cut"
alias mp4="yt-dlp-script mp4"
alias mp4-cut="yt-dlp-script mp4-cut"

# Claude / AI
alias cc="claude --allow-dangerously-skip-permissions"
alias c="claude --allow-dangerously-skip-permissions"
alias oc="opencode"
alias o="opencode"

# Nix
alias update="nix flake update --flake \$(readlink -f /etc/nixos/)"
alias cza="chezmoi apply --force"

# yazi with cwd sync
function yy() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

# --- fzf Configuration ---
export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border
  --color=bg+:#414559,bg:#303446,spinner:#f2d5cf,hl:#e78284
  --color=fg:#c6d0f5,header:#e78284,info:#ca9ee6,pointer:#f2d5cf
  --color=marker:#f2d5cf,fg+:#c6d0f5,prompt:#ca9ee6,hl+:#e78284"
