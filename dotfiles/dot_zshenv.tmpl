# Keep bootstrap-managed tools visible before the larger interactive shell setup
# has run. This file must stay small because zsh reads it for every shell.
if [ -r /etc/zshenv ]; then
  source /etc/zshenv
fi

typeset -U path PATH 2>/dev/null || true
case ":${PATH}:" in *":${HOME}/.local/bin:"*) ;; *) PATH="${HOME}/.local/bin:${PATH}" ;; esac
case ":${PATH}:" in *":${HOME}/.cargo/bin:"*) ;; *) PATH="${HOME}/.cargo/bin:${PATH}" ;; esac
export PATH

export BASH_ENV="${BASH_ENV:-$HOME/.bashenv}"
