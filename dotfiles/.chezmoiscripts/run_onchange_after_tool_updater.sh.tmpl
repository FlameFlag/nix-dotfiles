{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env sh
set -eu

# nd-tools.toml hash: {{ include "dot_config/nix-dotfiles/nd-tools.toml" | sha256sum }}
# tool-updates.toml hash: {{ include "dot_config/nix-dotfiles/tool-updates.toml" | sha256sum }}
# nd-tools-update.service hash: {{ include "dot_config/systemd/user/nd-tools-update.service" | sha256sum }}
# nd-tools-update.timer hash: {{ include "dot_config/systemd/user/nd-tools-update.timer" | sha256sum }}

if command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1; then
  systemctl --user daemon-reload
  systemctl --user enable --now nd-tools-update.timer
fi
{{- end -}}
