#!/usr/bin/env zsh
set -euo pipefail

default_fg="#c6d0f5"
default_bg="#303446"
overlay_home=""

{{- if eq .chezmoi.os "darwin" }}
if ! defaults read -g AppleInterfaceStyle >/dev/null 2>&1; then
  default_fg="#4c4f69"
  default_bg="#eff1f5"
fi
{{- else }}
if command -v gsettings >/dev/null 2>&1; then
  color_scheme="$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null || true)"
  if [[ "$color_scheme" != *"dark"* ]]; then
    default_fg="#4c4f69"
    default_bg="#eff1f5"
  fi
fi
{{- end }}

cleanup() {
  if [[ -n "${ZELLIJ:-}" ]] && command -v zellij >/dev/null 2>&1; then
    zellij action set-pane-color --reset </dev/null >/dev/null 2>&1 &!
  fi
  if [[ -n "$overlay_home" ]]; then
    rm -rf "$overlay_home"
  fi
}

if [[ -n "${ZELLIJ:-}" ]] && command -v zellij >/dev/null 2>&1; then
  zellij action set-pane-color --fg "$default_fg" --bg "$default_bg" </dev/null >/dev/null 2>&1 &!
  trap cleanup EXIT INT TERM
fi

trust_target="$(git rev-parse --show-toplevel 2>/dev/null || pwd -P)"
codex_home="${CODEX_HOME:-$HOME/.codex}"
overlay_home="$(REAL_CODEX_HOME="$codex_home" TRUST_TARGET="$trust_target" python3 - <<'PY'
from pathlib import Path
import os
import re
import tempfile

real_home = Path(os.environ["REAL_CODEX_HOME"]).expanduser()
trust_target = os.environ["TRUST_TARGET"]
overlay = Path(tempfile.mkdtemp(prefix="codex-trust-"))
real_home.mkdir(parents=True, exist_ok=True)

for entry in real_home.iterdir():
    if entry.name == "config.toml":
        continue
    target = overlay / entry.name
    try:
        target.symlink_to(entry, target_is_directory=entry.is_dir())
    except FileExistsError:
        pass

config_file = real_home / "config.toml"
lines = config_file.read_text().splitlines() if config_file.exists() else []
header = f'[projects."{trust_target}"]'

for i, line in enumerate(lines):
    if line.strip() != header:
        continue

    j = i + 1
    while j < len(lines) and not re.match(r"\s*\[", lines[j]):
        if re.match(r"\s*trust_level\s*=", lines[j]):
            lines[j] = 'trust_level = "trusted"'
            break
        j += 1
    else:
        lines.insert(i + 1, 'trust_level = "trusted"')
    break
else:
    if lines and lines[-1] != "":
        lines.append("")
    lines.extend([header, 'trust_level = "trusted"'])

overlay.joinpath("config.toml").write_text("\n".join(lines) + "\n")
print(overlay)
PY
)"

codex_status=0
CODEX_HOME="$overlay_home" codex "$@" || codex_status=$?
rm -rf "$overlay_home"
overlay_home=""
exit "$codex_status"
