# Fall back to a common terminfo entry on remote hosts without Ghostty support.
if [[ "$TERM" == "xterm-ghostty" ]] && ! infocmp xterm-ghostty &>/dev/null; then
  export TERM=xterm-256color
fi

# Prefer user-local tools installed by Ansible and language toolchains.
typeset -U path PATH
path=(
  {{- if eq .chezmoi.os "linux" }}
  "/usr/local/bin"
  "/usr/bin"
  "/bin"
  "/usr/sbin"
  "/sbin"
  {{- end }}
  "$HOME/.pi/agent/bin"
  "$HOME/.bun/bin"
  "$HOME/.bun/install/global/node_modules/.bin"
  "$HOME/.cache/.bun/bin"
  "$HOME/.npm/bin"
  "$HOME/.local/share/nix-dotfiles/immutable/profile/bin"
  "$HOME/.local/share/nix-dotfiles/immutable/bin"
  "$HOME/.local/bin"
  "$HOME/.cargo/bin"
  "$HOME/.go/bin"
  "$HOME/.yarn/bin"
  "${path[@]}"
)
if [[ -d /run/wrappers/bin ]]; then
  path=(/run/wrappers/bin "${path[@]}")
fi
export PATH

_command_wrapper() {
  emulate -L zsh
  local -r command_name=$1
  local -r command_path=$2
  local quoted_path

  printf -v quoted_path '%q' "$command_path"
  eval "$command_name() { command $quoted_path \"\$@\"; }"
}

_immutable_wrapper_marker="# nix-dotfiles: immutable-wrapper"
_is_immutable_wrapper_path() {
  emulate -L zsh
  [[ -f "$1" ]] && command grep -Fqx "$_immutable_wrapper_marker" "$1" 2>/dev/null
}
_is_immutable_wrapper_command() {
  emulate -L zsh
  local command_path
  command_path="$(command -v "$1" 2>/dev/null)" || return 1
  _is_immutable_wrapper_path "$command_path"
}

_nix_dotfiles_flake="${NIX_DOTFILES_FLAKE:-}"
if [[ -z "$_nix_dotfiles_flake" ]]; then
  case "$(uname -s 2>/dev/null)" in
    Darwin)
      _nix_dotfiles_candidates=("$HOME/Developer/nix-dotfiles" "$HOME/nix-dotfiles" "/etc/nixos")
      ;;
    *)
      _nix_dotfiles_candidates=("$HOME/nix-dotfiles" "/etc/nixos")
      ;;
  esac
  for _nix_dotfiles_dir in "${_nix_dotfiles_candidates[@]}"; do
    [[ -f "$_nix_dotfiles_dir/flake.nix" ]] || continue
    _nix_dotfiles_flake="$_nix_dotfiles_dir"
    break
  done
fi
if [[ -z "$_nix_dotfiles_flake" ]]; then
  _nix_dotfiles_flake="/etc/nixos"
fi
if [[ -d "$_nix_dotfiles_flake" ]]; then
  _nix_dotfiles_flake="$(
    cd -P -- "$_nix_dotfiles_flake" 2>/dev/null &&
      pwd ||
      printf '%s\n' "$_nix_dotfiles_flake"
  )"
fi
unset _nix_dotfiles_dir _nix_dotfiles_candidates

_immutable_nix_host=0
if _is_immutable_wrapper_command nix; then
  _immutable_nix_host=1
fi
_portable_nix_host=0
if [[ "$_immutable_nix_host" -eq 1 || ! -e /etc/NIXOS ]]; then
  _portable_nix_host=1
fi

_startup_command() {
  emulate -L zsh
  local command_path
  command_path="$(command -v "$1" 2>/dev/null)" || return 1
  if [[ "${2:-}" != "allow-wrapper" ]] && _is_immutable_wrapper_path "$command_path"; then
    command_path="$(PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin" command -v "$1" 2>/dev/null)" || return 1
  fi
  [[ -n "$command_path" ]] || return 1
  printf '%s\n' "$command_path"
}

# Load Oh My Zsh without its prompt or self-update behavior.
export ZSH="$HOME/.oh-my-zsh"
# shellcheck disable=SC2034
ZSH_THEME=""
# shellcheck disable=SC2034
DISABLE_AUTO_UPDATE="true"
# shellcheck disable=SC2034
DISABLE_UNTRACKED_FILES_DIRTY="true"

# Enable the Oh My Zsh plugins used in interactive sessions.
plugins=(
  git
  rust
  nmap
  rsync
  colored-man-pages
  sudo
  extract
  command-not-found
  copypath
  copyfile
  fzf-tab
  zsh-autosuggestions
  zsh-syntax-highlighting
)
if _startup_command gh >/dev/null; then
  plugins+=(gh)
fi

# Add cached completion definitions before Oh My Zsh runs compinit.
fpath=("$HOME/.cache/zsh/completions" "${fpath[@]}")

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  # shellcheck source=/dev/null
  source "$ZSH/oh-my-zsh.sh"
fi

# Load fzf's native key bindings without letting its completion widget take Tab
# away from fzf-tab.
_fzf_init() {
  emulate -L zsh
  local fzf_bin
  fzf_bin="$(_startup_command fzf)" || return
  _command_wrapper fzf "$fzf_bin"

  local init
  init="$(
    "$fzf_bin" --zsh | sed \
      -e '/^### completion\.zsh ###$/,$d' \
      -e '/^  eval \$__fzf_key_bindings_options$/i\
  __fzf_key_bindings_options=${__fzf_key_bindings_options/ zle on/}\
  __fzf_key_bindings_options=${__fzf_key_bindings_options/ zle off/}'
  )" || return

  eval "$init"
}
_fzf_init
unset -f _fzf_init

zstyle ':completion:*' menu no
zstyle ':completion:*:*:*:*:*' menu no
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' group-name ''
zstyle ':fzf-tab:*' switch-group '<' '>'
if (( $+functions[enable-fzf-tab] )); then
  enable-fzf-tab
fi

# Source pre-generated startup hooks to keep shell startup fast.
_starship_bin="$(_startup_command starship 2>/dev/null || true)"
if [[ -n "$_starship_bin" ]]; then
  _command_wrapper starship "$_starship_bin"
fi
if [[ -n "$_starship_bin" && -r "$HOME/.cache/starship/init.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.cache/starship/init.zsh"
elif [[ -n "$_starship_bin" ]]; then
  eval "$("$_starship_bin" init zsh)"
fi
unset _starship_bin
if _startup_command tv >/dev/null && [[ -r "$HOME/.cache/television/init.zsh" ]]; then
  # shellcheck source=/dev/null
  source "$HOME/.cache/television/init.zsh"
fi
_atuin_bin="$(_startup_command atuin allow-wrapper 2>/dev/null || true)"
if [[ -t 0 && -t 1 && -n "$_atuin_bin" && -r "$HOME/.cache/atuin/init.zsh" ]]; then
  _command_wrapper atuin "$_atuin_bin"
  # shellcheck source=/dev/null
  source "$HOME/.cache/atuin/init.zsh"
  _atuin_search() {
    emulate -L zsh
    zle -I

    local output result_file __atuin_status
    result_file="$(mktemp)" || return 1
    # shellcheck disable=SC2153
    ATUIN_SHELL=zsh ATUIN_LOG=error ATUIN_QUERY=$BUFFER atuin search "$@" -i --result-file "$result_file" </dev/tty >/dev/tty 2>/dev/tty
    __atuin_status=$?
    output="$(<"$result_file")"
    rm -f "$result_file"

    zle reset-prompt
    if [[ -n "${zle_bracketed_paste[1]-}" ]]; then
      print -rn -- "${zle_bracketed_paste[1]}" >/dev/tty
    fi

    if ((__atuin_status != 0)); then
      [[ -n "$output" ]] && print -r -- "$output" >/dev/tty
      return "$__atuin_status"
    fi

    if [[ -n "$output" ]]; then
      # shellcheck disable=SC2034
      RBUFFER=""
      LBUFFER=$output

      if [[ $LBUFFER == __atuin_accept__:* ]]; then
        LBUFFER=${LBUFFER#__atuin_accept__:}
        zle accept-line
      fi
    fi
  }
  zle -N atuin-search _atuin_search
  zle -N atuin-search-vicmd _atuin_search_vicmd
  zle -N atuin-search-viins _atuin_search_viins
fi
unset _atuin_bin

# Use 1Password locally, but preserve sshd's forwarded agent in SSH sessions.
{{- if eq .chezmoi.os "darwin" }}
_1p_ssh_auth_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- else }}
_1p_ssh_auth_sock="$HOME/.1password/agent.sock"
{{- end }}
if [[ -z "${SSH_CONNECTION:-}" ]]; then
  export SSH_AUTH_SOCK="$_1p_ssh_auth_sock"
fi
unset _1p_ssh_auth_sock

# Prefer Helix for command-line editing.
export EDITOR="hx"
export VISUAL="hx"

