model = "gpt-5.5"
model_reasoning_effort = "high"
suppress_unstable_features_warning = true

[features]
in_app_browser = true
browser_use = true
browser_use_external = true
computer_use = true

[tui]
notification_condition = "always"
show_tooltips = false
status_line = ["model-with-reasoning", "project-name", "context-remaining", "five-hour-limit", "weekly-limit"]
status_line_use_colors = true

[mcp_servers.ghidra]
url = "http://127.0.0.1:8090/mcp"
startup_timeout_sec = 60
tool_timeout_sec = 1800
enabled_tools = [
  "list_instances",
  "connect_instance",
  "list_tool_groups",
  "load_tool_group",
  "import_file",
  "get_current_program_info",
  "list_open_programs",
  "list_project_files",
  "get_project_info",
  "open_project",
  "load_program",
  "load_program_from_project",
  "switch_program",
  "save_program",
  "list_functions",
  "list_functions_enhanced",
  "search_functions",
  "search_functions_enhanced",
  "get_function_by_address",
  "get_function_signature",
  "get_function_variables",
  "get_function_callers",
  "get_function_callees",
  "get_function_call_graph",
  "get_function_xrefs",
  "get_xrefs_to",
  "get_xrefs_from",
  "get_bulk_xrefs",
  "decompile_function",
  "force_decompile",
  "disassemble_function",
  "get_function_pcode",
  "list_strings",
  "search_strings",
  "list_imports",
  "list_exports",
  "get_entry_points",
  "read_memory",
  "inspect_memory_content",
  "list_data_types",
  "search_data_types",
  "get_valid_data_types",
  "rename_function",
  "rename_function_by_address",
  "rename_variable",
  "rename_variables",
  "set_plate_comment",
  "set_disassembly_comment",
  "set_decompiler_comment",
  "list_bookmarks",
  "set_bookmark",
  "delete_bookmark",
  "batch_set_comments",
  "set_function_prototype",
  "set_parameter_type",
  "set_local_variable_type",
  "apply_data_type",
  "analyze_function_complete",
  "analyze_call_graph",
  "emulate_function",
]
