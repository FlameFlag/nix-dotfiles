{
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "Catppuccin Frappé",
  "workbench.preferredLightColorTheme": "Catppuccin Latte",
  "workbench.colorTheme": "Catppuccin Frappé",
  "workbench.iconTheme": "catppuccin-frappe",
  "files.associations": {
    "*.bash.tmpl": "shellscript",
    "*.fish.tmpl": "fish",
    "*.json.tmpl": "jsonc",
    "*.kdl.tmpl": "kdl",
    "*.lua.tmpl": "lua",
    "*.nix.tmpl": "nix",
    "*.nu.tmpl": "nushell",
    "*.sh.tmpl": "shellscript",
    ".*.toml.tmpl": "toml",
    "**/.chezmoiexternal.toml.tmpl": "toml",
    "*.toml.tmpl": "toml",
    "*.yaml.tmpl": "yaml",
    "*.yml.tmpl": "yaml",
    "*.zsh.tmpl": "shellscript",
    "**/.chezmoiscripts/*.sh.tmpl": "shellscript",
    "**/.chezmoitemplates/*.conf.tmpl": "properties",
    "**/dot_bash_profile.tmpl": "shellscript",
    "**/dot_bashenv.tmpl": "shellscript",
    "**/dot_bashrc.tmpl": "shellscript",
    "**/dot_gitconfig.tmpl": "gitconfig",
    "**/dot_ssh/config.tmpl": "ssh_config",
    "**/dot_zshenv.tmpl": "shellscript",
    "**/dot_zshrc.tmpl": "shellscript"
  },
  "shellcheck.ignorePatterns": {
    "**/*.csh": true,
    "**/*.cshrc": true,
    "**/*.fish": true,
    "**/*.login": true,
    "**/*.logout": true,
    "**/*.tcsh": true,
    "**/*.tcshrc": true,
    "**/*.xonshrc": true,
    "**/*.xsh": true,
    "**/*.zsh": true,
    "**/*.zshrc": true,
    "**/zshrc": true,
    "**/*.zprofile": true,
    "**/zprofile": true,
    "**/*.zlogin": true,
    "**/zlogin": true,
    "**/*.zlogout": true,
    "**/zlogout": true,
    "**/*.zshenv": true,
    "**/zshenv": true,
    "**/*.zsh-theme": true,
    "**/*.bash.tmpl": true,
    "**/*.sh.tmpl": true,
    "**/*.zsh.tmpl": true,
    "**/dot_bashrc.tmpl": true,
    "**/dot_zshrc.tmpl": true
  },
  "bashIde.shellcheckPath": "",
  "nushellLanguageServer.nushellExecutablePath": "nushell-lsp-filter",
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
}
