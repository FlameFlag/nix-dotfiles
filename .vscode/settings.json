{
  "files.associations": {
    "*.bash.tmpl": "shellscript",
    "*.fish.tmpl": "fish",
    "*.json.tmpl": "jsonc",
    "*.kdl.tmpl": "kdl",
    "*.lua.tmpl": "lua",
    "*.nix.tmpl": "nix",
    "*.nu.tmpl": "nushell",
    "*.sh.tmpl": "shellscript",
    ".*.toml.tmpl": "toml",
    "**/.chezmoiexternal.toml.tmpl": "toml",
    "*.toml.tmpl": "toml",
    "*.yaml.tmpl": "yaml",
    "*.yml.tmpl": "yaml",
    "*.zsh.tmpl": "shellscript"
  },
  "shellcheck.ignorePatterns": {
    "**/*.csh": true,
    "**/*.cshrc": true,
    "**/*.fish": true,
    "**/*.login": true,
    "**/*.logout": true,
    "**/*.tcsh": true,
    "**/*.tcshrc": true,
    "**/*.xonshrc": true,
    "**/*.xsh": true,
    "**/*.zsh": true,
    "**/*.zshrc": true,
    "**/zshrc": true,
    "**/*.zprofile": true,
    "**/zprofile": true,
    "**/*.zlogin": true,
    "**/zlogin": true,
    "**/*.zlogout": true,
    "**/zlogout": true,
    "**/*.zshenv": true,
    "**/zshenv": true,
    "**/*.zsh-theme": true,
    "**/*.bash.tmpl": true,
    "**/*.sh.tmpl": true,
    "**/*.zsh.tmpl": true,
    "**/dot_bashrc.tmpl": true,
    "**/dot_zshrc.tmpl": true
  },
  "bashIde.shellcheckPath": "",
  "nushellLanguageServer.nushellExecutablePath": ".vscode/lsp-diagnostic-filter/dist/nushell-lsp-filter.mjs",
  "zig.path": "zig",
  "zig.zls.path": "zls",
  "zig.zls.enabled": "on",
  "zig.formattingProvider": "zls",
  "zig.buildOnSaveProvider": "auto",
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
  "[zig]": {
    "editor.defaultFormatter": "ziglang.vscode-zig",
    "editor.formatOnSave": true,
    "editor.suggest.insertMode": "replace"
  }
}
