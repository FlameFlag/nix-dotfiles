{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "types": ["bun"],
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "dotfiles/.chezmoi-lib/**/*.ts",
    "dotfiles/.chezmoiscripts/**/*.ts"
  ]
}
