# Start from an empty build context and add back only what the smoke-test
# Dockerfile needs for Cargo, Scaffold config, and the focused chezmoi apply.
*

!Cargo.lock
!Cargo.toml
!Dockerfile
!.dockerignore
!scaffold.scm

!.scaffold/
!.scaffold/**

!crates/
!crates/**

!dotfiles/
!dotfiles/**

!packages/
packages/*
!packages/gh-hide-comment/
!packages/gh-hide-comment/**
!packages/http-fixture/
!packages/http-fixture/**
!packages/lenovo-con-mode/
!packages/lenovo-con-mode/**
!packages/lsp-diagnostic-filter/
!packages/lsp-diagnostic-filter/**
!packages/scm-fmt/
!packages/scm-fmt/**
!packages/system-run-mcp/
!packages/system-run-mcp/**
!packages/zellij-theme-tools/
!packages/zellij-theme-tools/**

# Never send local generated state if it appears under an included path.
**/.DS_Store
**/__pycache__/
**/*.pyc
**/target/
*.log
