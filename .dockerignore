# Start from an empty build context and add back only what the smoke-test
# Dockerfile needs for the Go helper, Scaffold config, and the focused
# chezmoi apply.
*

!Dockerfile
!.dockerignore
!go.mod
!go.sum
!scaffold.scm

!cmd/
!cmd/chezmoi-support/
!cmd/chezmoi-support/**

!internal/
!internal/**

!.scaffold/
!.scaffold/**

!scaffold/
!scaffold/**

!crates/
!crates/**

!dotfiles/
!dotfiles/**

!packages/
packages/*
!packages/gh-hide-comment/
!packages/gh-hide-comment/**
!packages/http-fixture/
!packages/http-fixture/**
!packages/lenovo-con-mode/
!packages/lenovo-con-mode/**
!packages/lsp-diagnostic-filter/
!packages/lsp-diagnostic-filter/**
!packages/scm-fmt/
!packages/scm-fmt/**
!packages/system-run-mcp/
!packages/system-run-mcp/**
!packages/zellij-theme-tools/
!packages/zellij-theme-tools/**

# Never send local generated state if it appears under an included path.
**/.DS_Store
**/__pycache__/
**/*.pyc
**/target/
.docker-cache/
*.log
