+fn set_physical_caps_lock_leds(state: bool) -> Result<(), io::Error> {
+    let manager = unsafe { IOHIDManagerCreate(kCFAllocatorDefault, 0) };
+    if manager.is_null() {
+        return Err(io::Error::other("IOHIDManagerCreate failed"));
+    }
+
+    let result = (|| {
+        let keyboard_match = keyboard_matching_dictionary();
+        let match_array = CFArray::from_CFTypes(&[keyboard_match.as_CFType()]);
+        unsafe {
+            IOHIDManagerSetDeviceMatchingMultiple(manager, match_array.as_concrete_TypeRef());
+        }
+
+        let kr = unsafe { IOHIDManagerOpen(manager, 0) };
+        if kr != KERN_SUCCESS {
+            return Err(io::Error::other(format!(
+                "IOHIDManagerOpen(keyboards) failed: {kr:#x}"
+            )));
+        }
+
+        let devices = unsafe { IOHIDManagerCopyDevices(manager) };
+        if devices.is_null() {
+            unsafe {
+                IOHIDManagerClose(manager, 0);
+            }
+            return Ok(());
+        }
+
+        let led_match = caps_lock_led_element_matching_dictionary();
+        let mut first_error: Option<io::Error> = None;
+        let mut updated_count = 0usize;
+
+        let device_count = unsafe { CFSetGetCount(devices) };
+        let mut device_values = vec![std::ptr::null(); device_count.max(0) as usize];
+        unsafe {
+            CFSetGetValues(devices, device_values.as_mut_ptr());
+        }
+
+        for device in device_values {
+            let device = device as IOHIDDeviceRef;
+            if device.is_null() {
+                continue;
+            }
+
+            let open_kr = unsafe { IOHIDDeviceOpen(device, 0) };
+            let device_was_opened = open_kr == KERN_SUCCESS;
+            if !device_was_opened {
+                log::trace!(
+                    "failed to open HID keyboard while setting Caps Lock LED; \
+                     attempting LED write anyway: {open_kr:#x}"
+                );
+            }
+
+            let elements = unsafe {
+                IOHIDDeviceCopyMatchingElements(device, led_match.as_concrete_TypeRef(), 0)
+            };
+            if elements.is_null() {
+                if device_was_opened {
+                    unsafe {
+                        IOHIDDeviceClose(device, 0);
+                    }
+                }
+                continue;
+            }
+
+            let element_count = unsafe { CFArrayGetCount(elements) };
+            for i in 0..element_count {
+                let element = unsafe { CFArrayGetValueAtIndex(elements, i) as IOHIDElementRef };
+                if element.is_null() {
+                    continue;
+                }
+
+                let value = if state {
+                    unsafe { IOHIDElementGetLogicalMax(element) }
+                } else {
+                    unsafe { IOHIDElementGetLogicalMin(element) }
+                };
+                let hid_value = unsafe {
+                    IOHIDValueCreateWithIntegerValue(
+                        kCFAllocatorDefault,
+                        element,
+                        mach_absolute_time(),
+                        value,
+                    )
+                };
+                if hid_value.is_null() {
+                    continue;
+                }
+
+                let set_kr = unsafe { IOHIDDeviceSetValue(device, element, hid_value) };
+                unsafe {
+                    CFRelease(hid_value as _);
+                }
+
+                if set_kr == KERN_SUCCESS {
+                    updated_count += 1;
+                } else if first_error.is_none() {
+                    first_error = Some(io::Error::other(format!(
+                        "IOHIDDeviceSetValue(Caps Lock LED={state}) failed: {set_kr:#x}"
+                    )));
+                }
+            }
+
+            unsafe {
+                CFRelease(elements as _);
+                if device_was_opened {
+                    IOHIDDeviceClose(device, 0);
+                }
+            }
+        }
+
+        unsafe {
+            CFRelease(devices as _);
+            IOHIDManagerClose(manager, 0);
+        }
+
+        if updated_count == 0
+            && let Some(error) = first_error
+        {
+            Err(error)
+        } else {
+            Ok(())
+        }
+    })();
+
+    unsafe {
+        CFRelease(manager as _);
+    }
+
+    result
+}
+
+fn toggle_caps_lock_state_and_led() -> Result<(), io::Error> {
+    let new_state = !get_caps_lock_state()?;
+    set_caps_lock_state(new_state)?;
+    if let Err(error) = set_physical_caps_lock_leds(new_state) {
+        log::warn!("failed to update physical Caps Lock LED: {error}");
+    }
+    Ok(())
+}
