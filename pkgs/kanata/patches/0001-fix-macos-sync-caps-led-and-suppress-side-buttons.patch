+fn with_hid_system_connect<T>(f: impl FnOnce(libc::mach_port_t) -> T) -> Result<T, io::Error> {
+    let service_name = c"IOHIDSystem";
+    let service = unsafe {
+        let matching = IOServiceMatching(service_name.as_ptr());
+        if matching.is_null() {
+            return Err(io::Error::other("IOServiceMatching(IOHIDSystem) failed"));
+        }
+
+        // IOServiceGetMatchingService consumes the matching dictionary.
+        IOServiceGetMatchingService(0, matching)
+    };
+
+    if service == 0 {
+        return Err(io::Error::other("IOHIDSystem service not found"));
+    }
+
+    let mut connect = 0;
+    let open_result = unsafe {
+        let kr = IOServiceOpen(
+            service,
+            libc::mach_task_self(),
+            K_IOHID_PARAM_CONNECT_TYPE,
+            &mut connect,
+        );
+        IOObjectRelease(service);
+        kr
+    };
+    if open_result != KERN_SUCCESS {
+        return Err(io::Error::other(format!(
+            "IOServiceOpen(IOHIDSystem) failed: {open_result:#x}"
+        )));
+    }
+
+    let result = f(connect);
+    unsafe {
+        IOServiceClose(connect);
+    }
+    Ok(result)
+}
+
+fn get_caps_lock_state() -> Result<bool, io::Error> {
+    with_hid_system_connect(|connect| {
+        let mut state = false;
+        let kr = unsafe { IOHIDGetModifierLockState(connect, K_IOHID_CAPS_LOCK_STATE, &mut state) };
+        if kr == KERN_SUCCESS {
+            Ok(state)
+        } else {
+            Err(io::Error::other(format!(
+                "IOHIDGetModifierLockState(caps) failed: {kr:#x}"
+            )))
+        }
+    })?
+}
+
+fn set_caps_lock_state(state: bool) -> Result<(), io::Error> {
+    with_hid_system_connect(|connect| {
+        let kr = unsafe { IOHIDSetModifierLockState(connect, K_IOHID_CAPS_LOCK_STATE, state) };
+        if kr == KERN_SUCCESS {
+            Ok(())
+        } else {
+            Err(io::Error::other(format!(
+                "IOHIDSetModifierLockState(caps={state}) failed: {kr:#x}"
+            )))
+        }
+    })?
+}
