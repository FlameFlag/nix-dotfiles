+fn send_mapped_mouse_button_event(
+    tx: &Sender<KeyEvent>,
+    event_type: u32,
+    button_number: i64,
+) -> bool {
+    let mut key_event = match key_event_from_mouse_event(event_type, button_number) {
+        Some(ev) => ev,
+        None => return false,
+    };
+
+    if !crate::kanata::MAPPED_KEYS.lock().contains(&key_event.code) {
+        return false;
+    }
+
+    match key_event.value {
+        KeyValue::Release => {
+            crate::kanata::PRESSED_KEYS.lock().remove(&key_event.code);
+        }
+        KeyValue::Press => {
+            let mut pressed_keys = crate::kanata::PRESSED_KEYS.lock();
+            if pressed_keys.contains(&key_event.code) {
+                key_event.value = KeyValue::Repeat;
+            } else {
+                pressed_keys.insert(key_event.code);
+            }
+        }
+        _ => {}
+    }
+
+    log::debug!("mouse tap: {key_event:?}");
+
+    if let Err(e) = tx.try_send(key_event) {
+        log::warn!("mouse tap: failed to send event: {e}");
+        return false;
+    }
+
+    true
+}
+
+fn mapped_aux_button_bits() -> u64 {
+    let mapped_keys = crate::kanata::MAPPED_KEYS.lock();
+    let mut bits = 0;
+    if mapped_keys.contains(&OsCode::BTN_MIDDLE) {
+        bits |= 1_u64 << 2;
+    }
+    if mapped_keys.contains(&OsCode::BTN_SIDE) {
+        bits |= 1_u64 << 3;
+    }
+    if mapped_keys.contains(&OsCode::BTN_EXTRA) {
+        bits |= 1_u64 << 4;
+    }
+    bits
+}
+
+fn aux_mouse_button_change(event: CGEventRef) -> Option<(u64, u64)> {
+    let ns_event_class = Class::get("NSEvent")?;
+    let ns_event: *mut Object = unsafe { msg_send![ns_event_class, eventWithCGEvent: event] };
+    if ns_event.is_null() {
+        return None;
+    }
+
+    let event_type: i64 = unsafe { msg_send![ns_event, type] };
+    if event_type != NX_SYSDEFINED as i64 {
+        return None;
+    }
+
+    let subtype: i16 = unsafe { msg_send![ns_event, subtype] };
+    if !matches!(
+        subtype,
+        NX_SUBTYPE_AUX_MOUSE_BUTTONS | NX_SUBTYPE_AUX_CONTROL_BUTTONS
+    ) {
+        return None;
+    }
+
+    let changed_buttons: i64 = unsafe { msg_send![ns_event, data1] };
+    let button_state: i64 = unsafe { msg_send![ns_event, data2] };
+    Some((changed_buttons as u64, button_state as u64))
+}
