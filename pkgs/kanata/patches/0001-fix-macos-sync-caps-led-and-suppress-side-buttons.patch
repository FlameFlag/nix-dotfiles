+unsafe extern "C" fn raw_mouse_event_tap_callback(
+    _proxy: CGEventTapProxy,
+    event_type: u32,
+    event: CGEventRef,
+    _user_info: *const c_void,
+) -> CGEventRef {
+    let tx = match MOUSE_TAP_TX.get() {
+        Some(tx) => tx,
+        None => return event,
+    };
+
+    if matches!(
+        event_type,
+        x if x == CGEventType::MouseMoved as u32
+            || x == CGEventType::LeftMouseDragged as u32
+            || x == CGEventType::RightMouseDragged as u32
+            || x == CGEventType::OtherMouseDragged as u32
+    ) {
+        let mmk_slot = match MOUSE_MOVEMENT_KEY.get() {
+            Some(slot) => slot,
+            None => return event,
+        };
+        if let Some(code) = *mmk_slot.lock() {
+            let fake = KeyEvent {
+                code,
+                value: KeyValue::Tap,
+            };
+            if let Err(e) = tx.try_send(fake) {
+                log::trace!("mouse tap (movement): drop synthetic tap: {e}");
+            }
+        }
+        return event;
+    }
+
+    if event_type == CGEventType::ScrollWheel as u32 {
+        let Some(key_event) = raw_scroll_event_to_key_event(event) else {
+            return event;
+        };
+        if !crate::kanata::MAPPED_KEYS.lock().contains(&key_event.code) {
+            return event;
+        }
+        log::debug!("mouse tap (wheel): {key_event:?}");
+        if let Err(e) = tx.try_send(key_event) {
+            log::warn!("mouse tap: failed to send wheel event: {e}");
+            return event;
+        }
+        return std::ptr::null_mut();
