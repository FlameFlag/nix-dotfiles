+type AudioObjectID = u32;
+type AudioObjectPropertySelector = u32;
+type AudioObjectPropertyScope = u32;
+type AudioObjectPropertyElement = u32;
+type OSStatus = i32;
+
+#[repr(C)]
+struct AudioObjectPropertyAddress {
+    selector: AudioObjectPropertySelector,
+    scope: AudioObjectPropertyScope,
+    element: AudioObjectPropertyElement,
+}
+
+const fn fourcc(bytes: &[u8; 4]) -> u32 {
+    ((bytes[0] as u32) << 24)
+        | ((bytes[1] as u32) << 16)
+        | ((bytes[2] as u32) << 8)
+        | bytes[3] as u32
+}
+
+const K_AUDIO_OBJECT_SYSTEM_OBJECT: AudioObjectID = 1;
+const K_AUDIO_OBJECT_PROPERTY_ELEMENT_MAIN: AudioObjectPropertyElement = 0;
+const K_AUDIO_HARDWARE_PROPERTY_DEFAULT_OUTPUT_DEVICE: AudioObjectPropertySelector =
+    fourcc(b"dOut");
+const K_AUDIO_DEVICE_PROPERTY_VOLUME_SCALAR: AudioObjectPropertySelector = fourcc(b"volm");
+const K_AUDIO_OBJECT_PROPERTY_SCOPE_GLOBAL: AudioObjectPropertyScope = fourcc(b"glob");
+const K_AUDIO_DEVICE_PROPERTY_SCOPE_OUTPUT: AudioObjectPropertyScope = fourcc(b"outp");
+
+#[link(name = "CoreAudio", kind = "framework")]
+unsafe extern "C" {
+    fn AudioObjectHasProperty(
+        object_id: AudioObjectID,
+        address: *const AudioObjectPropertyAddress,
+    ) -> u8;
+    fn AudioObjectGetPropertyData(
+        object_id: AudioObjectID,
+        address: *const AudioObjectPropertyAddress,
+        qualifier_data_size: u32,
+        qualifier_data: *const c_void,
+        data_size: *mut u32,
+        data: *mut c_void,
+    ) -> OSStatus;
+    fn AudioObjectSetPropertyData(
+        object_id: AudioObjectID,
+        address: *const AudioObjectPropertyAddress,
+        qualifier_data_size: u32,
+        qualifier_data: *const c_void,
+        data_size: u32,
+        data: *const c_void,
+    ) -> OSStatus;
+}
+
+fn coreaudio_error(operation: &str, status: OSStatus) -> io::Error {
+    io::Error::other(format!("{operation} failed with OSStatus {status}"))
+}
+
+fn coreaudio_get_default_output_device() -> Result<AudioObjectID, io::Error> {
+    let address = AudioObjectPropertyAddress {
+        selector: K_AUDIO_HARDWARE_PROPERTY_DEFAULT_OUTPUT_DEVICE,
+        scope: K_AUDIO_OBJECT_PROPERTY_SCOPE_GLOBAL,
+        element: K_AUDIO_OBJECT_PROPERTY_ELEMENT_MAIN,
+    };
+    let mut device: AudioObjectID = 0;
+    let mut size = std::mem::size_of::<AudioObjectID>() as u32;
+    let status = unsafe {
+        AudioObjectGetPropertyData(
+            K_AUDIO_OBJECT_SYSTEM_OBJECT,
+            &address,
+            0,
+            std::ptr::null(),
+            &mut size,
+            &mut device as *mut AudioObjectID as *mut c_void,
+        )
+    };
+    if status == 0 {
+        Ok(device)
+    } else {
+        Err(coreaudio_error(
+            "AudioObjectGetPropertyData(default output)",
+            status,
+        ))
+    }
+}
+
+fn coreaudio_volume_address(element: AudioObjectPropertyElement) -> AudioObjectPropertyAddress {
+    AudioObjectPropertyAddress {
+        selector: K_AUDIO_DEVICE_PROPERTY_VOLUME_SCALAR,
+        scope: K_AUDIO_DEVICE_PROPERTY_SCOPE_OUTPUT,
+        element,
+    }
+}
+
+fn coreaudio_get_volume(
+    device: AudioObjectID,
+    element: AudioObjectPropertyElement,
+) -> Result<f32, io::Error> {
+    let address = coreaudio_volume_address(element);
+    if unsafe { AudioObjectHasProperty(device, &address) } == 0 {
+        return Err(io::Error::other("volume property unavailable"));
+    }
+    let mut volume = 0.0_f32;
+    let mut size = std::mem::size_of::<f32>() as u32;
+    let status = unsafe {
+        AudioObjectGetPropertyData(
+            device,
+            &address,
+            0,
+            std::ptr::null(),
+            &mut size,
+            &mut volume as *mut f32 as *mut c_void,
+        )
+    };
+    if status == 0 {
+        Ok(volume)
+    } else {
+        Err(coreaudio_error(
+            "AudioObjectGetPropertyData(volume)",
+            status,
+        ))
+    }
+}
+
+fn coreaudio_set_volume(
+    device: AudioObjectID,
+    element: AudioObjectPropertyElement,
+    volume: f32,
+) -> Result<(), io::Error> {
+    let address = coreaudio_volume_address(element);
+    if unsafe { AudioObjectHasProperty(device, &address) } == 0 {
+        return Ok(());
+    }
+    let status = unsafe {
+        AudioObjectSetPropertyData(
+            device,
+            &address,
+            0,
+            std::ptr::null(),
+            std::mem::size_of::<f32>() as u32,
+            &volume as *const f32 as *const c_void,
+        )
+    };
+    if status == 0 {
+        Ok(())
+    } else {
+        Err(coreaudio_error(
+            "AudioObjectSetPropertyData(volume)",
+            status,
+        ))
+    }
+}
+
+fn adjust_default_output_volume(delta: f32) -> Result<(), io::Error> {
+    let device = coreaudio_get_default_output_device()?;
+    let current = coreaudio_get_volume(device, K_AUDIO_OBJECT_PROPERTY_ELEMENT_MAIN)
+        .or_else(|_| coreaudio_get_volume(device, 1))
+        .or_else(|_| coreaudio_get_volume(device, 2))?;
+    let next = (current + delta).clamp(0.0, 1.0);
+
+    let mut set_any = false;
+    for element in [K_AUDIO_OBJECT_PROPERTY_ELEMENT_MAIN, 1, 2] {
+        if coreaudio_set_volume(device, element, next).is_ok() {
+            set_any = true;
+        }
+    }
+
+    if set_any {
+        Ok(())
+    } else {
+        Err(io::Error::other("no writable output volume property found"))
+    }
+}
+
 #[cfg(all(not(feature = "simulated_output"), not(feature = "passthru_ahk")))]
 impl KbdOut {
     pub fn new() -> Result<Self, io::Error> {
@@ -1301,6 +1561,43 @@ impl KbdOut {
     }
 
     pub fn write_key(&mut self, key: OsCode, value: KeyValue) -> Result<(), io::Error> {
+        if matches!(key, OsCode::KEY_VOLUMEUP | OsCode::KEY_VOLUMEDOWN) {
+            let key_type = match key {
+                OsCode::KEY_VOLUMEUP => K_NX_KEYTYPE_SOUND_UP,
+                OsCode::KEY_VOLUMEDOWN => K_NX_KEYTYPE_SOUND_DOWN,
+                _ => unreachable!(),
+            };
+            let pressed = matches!(value, KeyValue::Press | KeyValue::Repeat | KeyValue::Tap);
+            match post_hid_aux_key(key_type, pressed) {
+                Ok(()) => {
+                    self.record_output_transition_after_write(key, value);
+                    return Ok(());
+                }
+                Err(error) => {
+                    static WARNED_MEDIA_KEY_POST_FAILURE: AtomicBool = AtomicBool::new(false);
+                    if !WARNED_MEDIA_KEY_POST_FAILURE.swap(true, Ordering::Relaxed) {
+                        log::warn!(
+                            "failed to post macOS media key event; falling back to CoreAudio + OSDUIHelper: {error}"
+                        );
+                    } else {
+                        log::debug!("failed to post macOS media key event for {key:?}: {error}");
+                    }
+                    if !pressed {
+                        return Ok(());
+                    }
+                }
+            }
+
+            let delta = match key {
+                OsCode::KEY_VOLUMEUP => 0.0625,
+                OsCode::KEY_VOLUMEDOWN => -0.0625,
+                _ => unreachable!(),
+            };
+            adjust_default_output_volume(delta)?;
+            self.record_output_transition_after_write(key, value);
+            return Ok(());
+        }
+
         if key == OsCode::KEY_CAPSLOCK {
             let result = match value {
                 KeyValue::Press | KeyValue::Repeat | KeyValue::Tap => {
@@ -1333,7 +1630,9 @@ impl KbdOut {
             log::debug!("couldn't write unrecognized OsCode {code}");
             return Err(io::Error::other("OsCode not recognized!"));
         };
-        if key == OsCode::KEY_CAPSLOCK {
+        if key == OsCode::KEY_CAPSLOCK
+            || matches!(key, OsCode::KEY_VOLUMEUP | OsCode::KEY_VOLUMEDOWN)
+        {
             return self.write_key(key, value);
         }
         if let Ok(event) = InputEvent::try_from(KeyEvent { value, code: key }) {
