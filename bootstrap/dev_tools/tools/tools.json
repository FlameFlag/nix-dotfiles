        "package": {
          "manager": "uv",
          "name": "ty"
        }
      }
    },
    {
      "name": "gh-hide-comment",
      "platforms": [
        "macos",
        "linux",
        "windows"
      ],
      "bins": [
        {
          "name": "gh-hide-comment",
          "version_argv": [
            "sh",
            "-c",
            "command -v gh-hide-comment >/dev/null && printf installed"
          ]
        }
      ],
      "action": {
        "type": "build",
        "build": {
          "system": "zig",
          "path": "pkgs/gh-hide-comment"
        }
      }
    },
    {
      "name": "lenovo-con-mode",
      "platforms": [
        "linux",
        "windows"
      ],
      "requires": [
