    },
    {
      "name": "vscode",
      "bins": [
        {
          "name": "code",
          "version_argv": [
            "code",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "archive",
        "source": {
          "type": "direct",
          "version": "latest",
          "url": "https://update.code.visualstudio.com/latest/{platform}/stable"
        },
        "platforms": [
          {
            "when": {
              "os": "macos",
              "arch": "aarch64"
            },
            "platform": "darwin-arm64",
            "kind": "zip",
            "strip_components": 0,
            "links": [
              {
                "name": "code",
                "path": "Visual Studio Code.app/Contents/Resources/app/bin/code"
              }
            ],
            "app_links": [
              {
                "name": "Visual Studio Code.app",
                "path": "Visual Studio Code.app"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "aarch64"
            },
            "platform": "linux-arm64",
            "kind": "tar_gz",
            "strip_components": 1,
            "links": [
              {
                "name": "code",
                "path": "bin/code"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "x86_64"
            },
            "platform": "linux-x64",
            "kind": "tar_gz",
            "strip_components": 1,
            "links": [
              {
                "name": "code",
                "path": "bin/code"
              }
            ]
          }
