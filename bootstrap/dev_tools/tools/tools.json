{
  "$schema": "./tools.schema.json",
  "tools": [
    {
      "name": "chezmoi",
      "bins": [
        {
          "name": "chezmoi",
          "version_argv": [
            "chezmoi",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "script",
        "script": {
          "unix": {
            "url": "https://get.chezmoi.io",
            "file": "install.sh",
            "argv": [
              "sh",
              "{file}",
              "-b",
              "{bin_dir}"
            ]
          },
          "windows": {
            "url": "https://get.chezmoi.io/ps1",
            "file": "install.ps1",
            "argv": [
              "pwsh",
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "{file}",
              "-BinDir",
              "{bin_dir}"
            ]
          }
        }
      }
    },
    {
      "name": "uv",
      "bins": [
        {
          "name": "uv",
          "version_argv": [
            "uv",
            "--version"
          ]
        },
        {
          "name": "uvx",
          "version_argv": [
            "uvx",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "archive",
        "source": {
          "type": "github_latest",
          "repo": "astral-sh/uv",
          "tag_prefix": "v",
          "asset": "uv-{platform}.tar.gz"
        },
        "platforms": [
          {
            "when": {
              "os": "macos",
              "arch": "aarch64"
            },
            "platform": "aarch64-apple-darwin",
            "kind": "tar_gz",
            "strip_components": 1,
            "links": [
              {
                "name": "uv",
                "path": "uv"
              },
              {
                "name": "uvx",
                "path": "uvx"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "aarch64"
            },
            "platform": "aarch64-unknown-linux-gnu",
            "kind": "tar_gz",
            "strip_components": 1,
            "links": [
              {
                "name": "uv",
                "path": "uv"
              },
              {
                "name": "uvx",
                "path": "uvx"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "x86_64"
            },
            "platform": "x86_64-unknown-linux-gnu",
            "kind": "tar_gz",
            "strip_components": 1,
            "links": [
              {
                "name": "uv",
                "path": "uv"
              },
              {
                "name": "uvx",
                "path": "uvx"
              }
            ]
          },
          {
            "when": {
              "os": "windows",
              "arch": "x86_64"
            },
            "platform": "x86_64-pc-windows-msvc",
            "source": {
              "type": "github_latest",
              "repo": "astral-sh/uv",
              "tag_prefix": "v",
              "asset": "uv-{platform}.zip"
            },
            "kind": "zip",
            "strip_components": 1,
            "links": [
              {
                "name": "uv",
                "path": "uv.exe"
              },
              {
                "name": "uvx",
                "path": "uvx.exe"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "zig",
      "bins": [
        {
          "name": "zig",
          "version_argv": [
            "zig",
            "version"
          ]
        }
      ],
      "action": {
        "type": "required"
      }
    },
    {
      "name": "rustup",
      "bins": [
        {
          "name": "rustup",
          "version_argv": [
            "rustup",
            "--version"
          ]
        },
        {
          "name": "cargo",
          "version_argv": [
            "cargo",
            "--version"
          ]
        },
        {
          "name": "rustc",
          "version_argv": [
            "rustc",
            "--version"
          ]
        },
        {
          "name": "rustfmt",
          "version_argv": [
            "rustfmt",
            "--version"
          ]
        },
        {
          "name": "cargo-clippy",
          "version_argv": [
            "cargo",
            "clippy",
            "--version"
          ]
        },
        {
          "name": "rust-analyzer",
          "version_argv": [
            "rust-analyzer",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "toolchain",
        "toolchain": {
          "manager": "rustup",
          "name": "stable",
          "components": [
            "rustfmt",
            "clippy",
            "rust-analyzer",
            "rust-src"
          ],
          "install": {
            "unix": {
              "url": "https://sh.rustup.rs",
              "file": "install.sh",
              "argv": [
                "sh",
                "{file}",
                "-y",
                "--no-modify-path",
                "--profile",
                "minimal",
                "--default-toolchain",
                "{toolchain}",
                "{components}"
              ]
            },
            "windows": {
              "url": "https://static.rust-lang.org/rustup/dist/x86_64-pc-windows-msvc/rustup-init.exe",
              "file": "rustup-init.exe",
              "argv": [
                "{file}",
                "-y",
                "--no-modify-path",
                "--profile",
                "minimal",
                "--default-toolchain",
                "{toolchain}",
                "{components}"
              ]
            }
          },
          "update_argv": [
            "{manager_bin}",
            "toolchain",
            "install",
            "{toolchain}",
            "--profile",
            "minimal",
            "{components}"
          ],
          "active_argv": [
            "{manager_bin}",
            "show",
            "active-toolchain"
          ],
          "default_argv": [
            "{manager_bin}",
            "default",
            "{toolchain}"
          ],
          "component_argv": [
            "--component",
            "{component}"
          ]
        }
      }
    },
    {
      "name": "zls",
      "bins": [
        {
          "name": "zls",
          "version_argv": [
            "zls",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "archive",
        "source": {
          "type": "github_latest",
          "repo": "zigtools/zls",
          "asset": "zls-{platform}.tar.xz"
        },
        "platforms": [
          {
            "when": {
              "os": "macos",
              "arch": "aarch64"
            },
            "platform": "aarch64-macos",
            "kind": "tar_xz",
            "strip_components": 0,
            "links": [
              {
                "name": "zls",
                "path": "zls"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "aarch64"
            },
            "platform": "aarch64-linux",
            "kind": "tar_xz",
            "strip_components": 0,
            "links": [
              {
                "name": "zls",
                "path": "zls"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "x86_64"
            },
            "platform": "x86_64-linux",
            "kind": "tar_xz",
            "strip_components": 0,
            "links": [
              {
                "name": "zls",
                "path": "zls"
              }
            ]
          },
          {
            "when": {
              "os": "windows",
              "arch": "x86_64"
            },
            "platform": "x86_64-windows",
            "source": {
              "type": "github_latest",
              "repo": "zigtools/zls",
              "asset": "zls-{platform}.zip"
            },
            "kind": "zip",
            "strip_components": 0,
            "links": [
              {
                "name": "zls",
                "path": "zls.exe"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "ziglint",
      "bins": [
        {
          "name": "ziglint",
          "version_argv": [
            "sh",
            "-c",
            "ziglint --version 2>&1"
          ]
        }
      ],
      "action": {
        "type": "archive",
        "source": {
          "type": "github_latest",
          "repo": "rockorager/ziglint",
          "tag_prefix": "v",
          "asset": "ziglint-{platform}.tar.gz"
        },
        "platforms": [
          {
            "when": {
              "os": "macos",
              "arch": "aarch64"
            },
            "platform": "aarch64-macos",
            "kind": "tar_gz",
            "strip_components": 0,
            "links": [
              {
                "name": "ziglint",
                "path": "ziglint"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "aarch64"
            },
            "platform": "aarch64-linux",
            "kind": "tar_gz",
            "strip_components": 0,
            "links": [
              {
                "name": "ziglint",
                "path": "ziglint"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "x86_64"
            },
            "platform": "x86_64-linux",
            "kind": "tar_gz",
            "strip_components": 0,
            "links": [
              {
                "name": "ziglint",
                "path": "ziglint"
              }
            ]
          },
          {
            "when": {
              "os": "windows",
              "arch": "x86_64"
            },
            "platform": "x86_64-windows",
            "source": {
              "type": "github_latest",
              "repo": "rockorager/ziglint",
              "tag_prefix": "v",
              "asset": "ziglint-{platform}.zip"
            },
            "kind": "zip",
            "strip_components": 0,
            "links": [
              {
                "name": "ziglint",
                "path": "ziglint.exe"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "node",
      "bins": [
        {
          "name": "node",
          "version_argv": [
            "node",
            "--version"
          ]
        },
        {
          "name": "npm",
          "version_argv": [
            "npm",
            "--version"
          ]
        },
        {
          "name": "npx",
          "version_argv": [
            "npx",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "archive",
        "source": {
          "type": "node_latest",
          "index_url": "https://nodejs.org/dist/index.json",
          "url": "https://nodejs.org/dist/{version}/node-{version}-{platform}.tar.xz"
        },
        "platforms": [
          {
            "when": {
              "os": "macos",
              "arch": "aarch64"
            },
            "platform": "darwin-arm64",
            "kind": "tar_xz",
            "strip_components": 1,
            "links": [
              {
                "name": "node",
                "path": "bin/node"
              },
              {
                "name": "npm",
                "path": "bin/npm"
              },
              {
                "name": "npx",
                "path": "bin/npx"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "aarch64"
            },
            "platform": "linux-arm64-musl",
            "kind": "tar_xz",
            "strip_components": 1,
            "links": [
              {
                "name": "node",
                "path": "bin/node"
              },
              {
                "name": "npm",
                "path": "bin/npm"
              },
              {
                "name": "npx",
                "path": "bin/npx"
              }
            ]
          },
          {
            "when": {
              "os": "linux",
              "arch": "x86_64"
            },
            "platform": "linux-x64-musl",
            "kind": "tar_xz",
            "strip_components": 1,
            "links": [
              {
                "name": "node",
                "path": "bin/node"
              },
              {
                "name": "npm",
                "path": "bin/npm"
              },
              {
                "name": "npx",
                "path": "bin/npx"
              }
            ]
