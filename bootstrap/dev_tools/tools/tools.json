    {
      "name": "yt-dlp",
      "bins": [
        {
          "name": "yt-dlp",
          "version_argv": [
            "yt-dlp",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "package",
        "package": {
          "manager": "uv",
          "name": "yt-dlp"
        }
      }
    },
    {
      "name": "yt-dlp-script",
      "bins": [
        {
          "name": "yt-dlp-script",
          "version_argv": [
            "sh",
            "-c",
            "command -v yt-dlp-script >/dev/null && printf installed"
          ]
        }
      ],
      "platforms": [
        "macos",
        "linux"
      ],
      "action": {
        "type": "script",
        "script": {
          "unix": {
            "url": "https://raw.githubusercontent.com/euvlok/pkgs/HEAD/pkgs/by-name/yt/yt-dlp-script/yt-dlp-script.nu",
            "file": "yt-dlp-script",
            "argv": [
              "sh",
              "-c",
              "set -eu\nscript_dir='{opt_dir}/yt-dlp-script/latest'\nscript_path=\"$script_dir/yt-dlp-script.nu\"\nwrapper='{bin_dir}/yt-dlp-script'\nmkdir -p \"$script_dir\"\ninstall -m 0644 '{file}' \"$script_path\"\ncat > \"$wrapper\" <<EOF\n#!/bin/sh\nunset PROMPT_MULTILINE_INDICATOR\nexec nu '$script_path' \"\\$@\"\nEOF\nchmod 0755 \"$wrapper\""
            ]
          }
        }
      }
    },
    {
      "name": "ruff",
      "bins": [
        {
          "name": "ruff",
          "version_argv": [
            "ruff",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "package",
        "package": {
          "manager": "uv",
          "name": "ruff"
        }
      }
    },
    {
