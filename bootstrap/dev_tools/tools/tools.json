              "url": "https://nodejs.org/dist/{version}/node-{version}-{platform}.zip"
            },
            "kind": "zip",
            "strip_components": 1,
            "links": [
              {
                "name": "node",
                "path": "node-{version}-{platform}/node.exe"
              },
              {
                "name": "npm",
                "path": "node-{version}-{platform}/npm.cmd"
              },
              {
                "name": "npx",
                "path": "node-{version}-{platform}/npx.cmd"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "bun",
      "bins": [
        {
          "name": "bun",
          "version_argv": [
            "bun",
            "--version"
          ]
        },
        {
          "name": "bunx",
          "version_argv": [
            "bunx",
            "--version"
          ]
        }
      ],
      "action": {
        "type": "archive",
        "source": {
          "type": "github_latest",
          "repo": "oven-sh/bun",
          "tag_prefix": "bun-v",
          "asset": "bun-{platform}.zip"
        },
        "platforms": [
          {
            "when": {
              "os": "macos",
              "arch": "aarch64"
            },
            "platform": "darwin-aarch64",
            "kind": "zip",
            "strip_components": 0,
            "links": [
