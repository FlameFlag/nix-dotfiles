{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FlameFlag/nix-dotfiles/bootstrap/dev_tools/tools/tools.schema.json",
  "title": "nix-dotfiles bootstrap tools manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tools"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tool"
      }
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "bins",
        "action"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bins": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/bin"
          }
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "macos",
              "linux",
              "windows"
            ]
          },
          "uniqueItems": true
        },
        "requires": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "lenovo_laptop"
            ]
          },
          "uniqueItems": true
        },
        "action": {
          "oneOf": [
            {
              "$ref": "#/$defs/requiredAction"
            },
            {
              "$ref": "#/$defs/scriptAction"
            },
            {
              "$ref": "#/$defs/toolchainAction"
            },
            {
              "$ref": "#/$defs/archiveAction"
            },
            {
              "$ref": "#/$defs/packageAction"
            },
            {
              "$ref": "#/$defs/buildAction"
            }
          ]
        }
      }
    },
    "bin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version_argv"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version_argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "requiredAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "required"
        },
        "phase": {
          "$ref": "#/$defs/phase"
        }
      }
    },
    "packageAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "package"
      ],
      "properties": {
        "type": {
          "const": "package"
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "package": {
          "$ref": "#/$defs/package"
        }
      }
    },
    "scriptAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "script"
      ],
      "properties": {
        "type": {
          "const": "script"
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "script": {
          "$ref": "#/$defs/script"
        }
      }
    },
    "toolchainAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "toolchain"
      ],
      "properties": {
        "type": {
          "const": "toolchain"
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "toolchain": {
          "$ref": "#/$defs/toolchain"
        }
      }
    },
    "buildAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "build"
      ],
      "properties": {
        "type": {
          "const": "build"
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "build": {
          "$ref": "#/$defs/build"
        }
      }
    },
    "archiveAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "source",
        "platforms"
      ],
      "properties": {
        "type": {
          "const": "archive"
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "source": {
          "oneOf": [
            {
              "$ref": "#/$defs/githubLatestSource"
            },
            {
              "$ref": "#/$defs/directSource"
            },
            {
              "$ref": "#/$defs/commandSource"
            },
            {
              "$ref": "#/$defs/nodeLatestSource"
            }
          ]
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/archivePlatform"
          }
        }
      }
    },
    "phase": {
      "enum": [
        "prerequisites",
        "archives",
        "packages",
        "builds"
      ]
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manager",
        "name"
      ],
      "properties": {
        "manager": {
          "enum": [
            "uv"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manager",
        "name",
        "components",
        "install",
        "update_argv",
        "active_argv",
        "default_argv",
        "component_argv"
      ],
      "properties": {
        "manager": {
          "enum": [
            "rustup"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "install": {
          "$ref": "#/$defs/toolchainInstall"
        },
        "update_argv": {
          "$ref": "#/$defs/argv"
        },
        "active_argv": {
          "$ref": "#/$defs/argv"
        },
        "default_argv": {
          "$ref": "#/$defs/argv"
        },
        "component_argv": {
          "$ref": "#/$defs/argv"
        }
      }
    },
    "toolchainInstall": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "unix"
          ]
        },
        {
          "required": [
            "windows"
          ]
        }
      ],
      "properties": {
        "unix": {
          "$ref": "#/$defs/scriptCommand"
        },
        "windows": {
          "$ref": "#/$defs/scriptCommand"
        }
      }
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "system": {
          "enum": [
            "zig"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "script": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "unix"
          ]
        },
        {
          "required": [
            "windows"
          ]
        }
      ],
      "properties": {
        "unix": {
          "$ref": "#/$defs/scriptCommand"
        },
        "windows": {
          "$ref": "#/$defs/scriptCommand"
        }
      }
    },
    "scriptCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "file",
        "argv"
      ],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "githubLatestSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "repo",
        "asset"
      ],
      "properties": {
        "type": {
          "const": "github_latest"
        },
        "repo": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/]+/[^/]+$"
        },
        "tag_prefix": {
          "type": "string"
        },
        "asset": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "directSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "version",
        "url"
      ],
      "properties": {
        "type": {
          "const": "direct"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "commandSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "argv",
        "url"
      ],
      "properties": {
        "type": {
          "const": "command"
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nodeLatestSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "index_url",
        "url"
      ],
      "properties": {
        "type": {
          "const": "node_latest"
        },
        "index_url": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "path"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "hostPredicate": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "os": {
          "enum": [
            "macos",
            "linux",
            "windows"
          ]
        },
        "arch": {
          "enum": [
            "aarch64",
            "x86_64"
          ]
        }
      }
    },
    "archivePlatform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "when",
        "platform",
        "kind",
        "strip_components",
        "links"
      ],
      "properties": {
        "when": {
          "$ref": "#/$defs/hostPredicate"
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "oneOf": [
            {
              "$ref": "#/$defs/githubLatestSource"
            },
            {
              "$ref": "#/$defs/directSource"
            },
            {
              "$ref": "#/$defs/commandSource"
            },
            {
              "$ref": "#/$defs/nodeLatestSource"
            }
          ]
        },
        "kind": {
          "enum": [
            "tar_xz",
            "tar_gz",
            "zip"
          ]
        },
        "strip_components": {
          "type": "integer",
          "minimum": 0
        },
        "links": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "app_links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    }
  }
}
